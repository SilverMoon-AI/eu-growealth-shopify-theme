{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}

{%- if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.image != blank -%}
  {%- style -%}
    @media screen and (max-width: 749px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before,
      #Slider-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
#Slider-{{ section.id }} .slideshow__controls {
    border: 0;
}
    @media screen and (min-width: 750px) {
      #Slider-{{ section.id }}::before,
      #Slider-{{ section.id }} .media::before {
        padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}
{%- style -%}
.section-{{ section.id }}-padding .slider-button_new {
    color: rgba(var(--color-foreground), 1);
    background: #ffffff5e;
    border: none;
    cursor: pointer;
    width: 5rem;
    height: 5rem;
    display: flex;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
}
.section-{{ section.id }}-padding button.slider-button.slider-button--next {
    right: 2rem;
}
.section-{{ section.id }}-padding button.slider-button.slider-button--prev {
    left: 2rem;
}
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding button.slider-button.slider-button--next {
    right: 6rem;
}
.section-{{ section.id }}-padding button.slider-button.slider-button--prev {
    left: 6rem;
}
  }
.section-{{ section.id }}-padding .slideshow_product_box{
  margin-top:2rem;
}
.section-{{ section.id }}-padding .slider-button .icon {
    height: 1.2rem;
}

.section-{{ section.id }}-padding button.slideshow__autoplay.slider-button.no-js-hidden {
    position: relative !important;
    border: 0;
    top: 0;
    bottom: 0;
    padding: 0 !important;
}

.section-{{ section.id }}-padding .slideshow__controls.slideshow__controls--top.slider-buttons.no-js-hidden.slideshow__controls--border-radius-mobile {
    margin-top: -4.4rem;
    border: 0 !important;
    position: static;
}
.section-{{ section.id }}-padding .slider-counter__link--active.slider-counter__link--dots .dot {
    background-color:#fff;
}
.section-{{ section.id }}-padding .slider-counter__link--dots .dot{
        border: .1rem solid #fff;
}

.section-{{ section.id }}-padding button.slideshow__autoplay.slider-button.no-js-hidden {color: #fff;}

.section-{{ section.id }}-padding svg.icon.icon-pause {
    color: #fff;
}
.section-{{ section.id }}-padding .slideshow__controls {
    display: none;
}

{%- if  product.metafields.custom.slideshow_product_two != blank -%}
.section-{{ section.id }}-padding .slideshow__controls {
    display: flex;
}
{%- endif -%}
{%- endstyle -%}
<div class="section-{{ section.id }}-padding">
{%- if product.metafields.custom.overview_content != blank -%}
  <div class="page-width">
    <h2 style="text-align: center;padding-top: 75px;padding-bottom: 15px;font-weight: 600;">Overview</h2>
    <div class="product__description rte quick-add-hidden" {{ block.shopify_attributes }}>
       {{ section.settings.overview_content }}
       </div>
  </div>
{%- endif -%}
{%- if product.metafields.custom.slideshow_product_one != blank -%}
<slideshow-component
  class="slideshow_product_box slider-mobile-gutter{% if section.settings.layout == 'grid' %} page-width{% endif %}{% if section.settings.show_text_below %} mobile-text-below{% endif %}"
  role="region"
  aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_info | escape }}"
>
  {%- if section.settings.auto_rotate and section.blocks.size > 1 -%}
    <div class="slideshow__controls slideshow__controls--top slider-buttons no-js-hidden{% if section.settings.show_text_below %} slideshow__controls--border-radius-mobile{% endif %}">
      <button
        type="button"
        class="slider-button slider-button--prev slider-button_new"
        name="previous"
        aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
        aria-controls="Slider-{{ section.id }}"
      >
        {% render 'icon-caret' %}
      </button>
      <div class="slider-counter slider-counter--{{ section.settings.slider_visual }}{% if section.settings.slider_visual == 'counter' or section.settings.slider_visual == 'numbers' %} caption{% endif %}">
        {%- if section.settings.slider_visual == 'counter' -%}
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ section.blocks.size }}</span>
        {%- else -%}
          <div class="slideshow__control-wrapper">
              {%- if  product.metafields.custom.slideshow_product_one != blank -%}
              <button
                class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                aria-controls="Slider-{{ section.id }}"
              >
                {%- if section.settings.slider_visual == 'numbers' -%}
                  {{ forloop.index -}}
                {%- else -%}
                  <span class="dot"></span>
                {%- endif -%}
              </button>
            {%- endif -%}
            {%- if  product.metafields.custom.slideshow_product_two != blank -%}
              <button
                class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                aria-controls="Slider-{{ section.id }}"
              >
                {%- if section.settings.slider_visual == 'numbers' -%}
                  {{ forloop.index -}}
                {%- else -%}
                  <span class="dot"></span>
                {%- endif -%}
              </button>
            {%- endif -%}
            {%- if  product.metafields.custom.slideshow_product_three != blank -%}
              <button
                class="slider-counter__link slider-counter__link--{{ section.settings.slider_visual }} link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                aria-controls="Slider-{{ section.id }}"
              >
                {%- if section.settings.slider_visual == 'numbers' -%}
                  {{ forloop.index -}}
                {%- else -%}
                  <span class="dot"></span>
                {%- endif -%}
              </button>
            {%- endif -%}
            {%- if  product.metafields.custom.slideshow_product_four != blank -%}
