      "settings": {
        "custom_liquid": "<div style=\"background:linear-gradient(165deg, #45ad96 0%, #4EB99F 40%, #6ec9b5 100%); padding:80px 40px; color:#fff;\">\n  <div style=\"max-width:1400px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; gap:60px; flex-wrap:wrap;\">\n    <div style=\"flex:1; min-width:320px;\">\n      <h2 style=\"margin:0 0 20px; font-size:56px; line-height:1.1; font-weight:700; color:#fff;\">Why Growers Choose Growealth</h2>\n      <p style=\"margin:0; font-size:24px; line-height:1.8; color:rgba(255,255,255,0.95);\">\n        Growealth makes indoor growing easier with carefully selected products, practical guidance, and a focus on reliable performance. We aim to help home growers and small indoor setups choose more confidently and grow more successfully.\n      </p>\n    </div>\n\n    <div style=\"flex:1; min-width:320px; display:flex; justify-content:center; gap:60px; flex-wrap:wrap; text-align:center;\">\n      <div>\n        <div style=\"width:180px; height:180px; border:6px solid rgba(255,255,255,0.65); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:28px; font-weight:700; color:#fff;\">\n          Practical\n        </div>\n        <div style=\"font-size:22px; line-height:1.5; color:#fff;\">Product Selection</div>\n      </div>\n\n      <div>\n        <div style=\"width:180px; height:180px; border:6px solid rgba(255,255,255,0.65); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:28px; font-weight:700; color:#fff;\">\n          Reliable\n        </div>\n        <div style=\"font-size:22px; line-height:1.5; color:#fff;\">Growing Support</div>\n      </div>\n    </div>\n  </div>\n</div>",
        "color_scheme": "",
        "padding_top": 40,
