    "collapsible_content_yFLGmB": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_9Dnm3F": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Why choose DE over traditional HPS?",
            "icon": "check_mark",
            "row_content": "<p>DE lights are the next step in HID lighting. The basic components remain the same, but the technology has evolved to allow the DE fixture to produce more blues and more reds in the PAR spectrum. This means the type of light your plants receive is closer to that of the sun. Another advantage of a DE ballast is that is produces more light than any 1000W HPS. Our class leading 160,300lumens not only gives your plants more light to feed on, but this is what allows the light to render a more comprehensive PAR value.</p>",
            "page": ""
          }
        },
        "collapsible_row_JKXYEA": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What frequency does the NanoluxDE Fixture operate at?",
            "icon": "check_mark",
            "row_content": "<p>Input frequency is 50/60Hz<br/>Output Frequency is ≥30KHz</p>",
            "page": ""
          }
        },
        "collapsible_row_cwT3Ht": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is the circuit protection or safety on DE Fixtures?",
            "icon": "check_mark",
            "row_content": "<p>When the electrical current to the fixture is not within operational range the ballast will shut itself off in order to protect the components from damage. The fixture will automatically restart when the operational electrical current range stabilizes.</p>",
            "page": ""
          }
        },
        "collapsible_row_pQ3kNb": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is the running KHz of the DE Ballast?",
            "icon": "check_mark",
            "row_content": "<p>≥100KHz</p>",
            "page": ""
          }
        },
        "collapsible_row_gGtrYW": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is the footprint of the NanoluxDE Double Ended Fixture?",
            "icon": "check_mark",
            "row_content": "<p>The NanoluxDE Double Ended Fixture was designed for a 5’ x 5’ growing grid.</p>",
            "page": ""
          }
        },
        "collapsible_row_EfpKjr": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Is the NanoluxDE Double Ended Fixture and RemoteDE Digital Ballast dimmable?",
            "icon": "check_mark",
            "row_content": "<p>Yes, both the ballast and fixture come equipped with 6 phase dimming (600-1215w).</p>",
            "page": ""
          }
        },
        "collapsible_row_8Wjaam": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What is the luminous flux output of the NanoluxDE Double Ended Fixture?",
            "icon": "check_mark",
            "row_content": "<p>The Nanolux DE fixture has the highest luminous flux output currently on the market at 160,300lm and an output of 1215 watts.</p>",
            "page": ""
          }
        },
        "collapsible_row_PTLmYL": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Does the NanoluxDE Double Ended Fixture have plastic sockets for the bulb?",
            "icon": "check_mark",
            "row_content": "<p>No, The NanoluxDE has exclusive ceramic receptacles instead of the industry standard plastic receptacles which can melt.</p>",
            "page": ""
          }
        },
        "collapsible_row_7CAXi9": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What bulbs are recommended for the NanoluxDE Double Ended Fixture and Remote DE Digital Ballast?",
            "icon": "check_mark",
            "row_content": "<p>Doubled Ended HPS (High Pressure Sodium) bulbs must be used in the NanoluxDE Fixture and Nanolux Remote DE Ballast. Both of the DE ballast and fixture are compatible with industry DE bulbs currently on the market.</p>",
            "page": ""
          }
        },
        "collapsible_row_33tR6y": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How long with the NanoluxDE Bulb last?",
            "icon": "check_mark",
            "row_content": "<p>We recommend you change you bulb every 8-9 months to maintain peak performance. After this period of time the spectrum and lumen output begin to diminish.</p>",
            "page": ""
          }
        },
        "collapsible_row_8DwjyH": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Can I pair a DE bulb with a regular HPS Ballast?",
            "icon": "check_mark",
            "row_content": "<p>No</p>",
            "page": ""
          }
        }
      },
